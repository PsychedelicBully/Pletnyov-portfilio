{
    "outputDirectory": "public",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/post/(.*)",
            "destination": "/post/index.html"
        },
        {
            "source": "/filters",
            "destination": "/filters.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}